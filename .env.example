# Tradekit Environment Variables
# ==============================
#
# Copy this file to `.env` (for standalone use) OR add these variables to
# your shared PAI `.env` at $PAI_DIR/.env when running inside a PAI install.
#
# Load order (highest precedence last):
#   1. System environment variables
#   2. $PAI_DIR/.env          — PAI ecosystem shared config
#   3. ~/.claude/.env         — Claude Code default
#   4. ./.env                 — project-local (standalone)
#
# SECURITY RULES:
#   1. NEVER commit .env files to git (.gitignore already protects you)
#   2. NEVER share API keys in issues, chats, or screenshots
#   3. Rotate keys if you suspect exposure
#
# Run `tradekit init` after install to populate this interactively.

# ============================================================
# DATA SOURCES
# ============================================================

# Finviz Elite — https://finviz.com/elite.ashx
# Used by: pre-market scanner, news feed
# Free tier: works for basic screening; Elite unlocks news + export
FINVIZ_API_KEY=

# Alpha Vantage — https://www.alphavantage.co/support/#api-key
# Used by: fundamentals, historical fallback when Yahoo is rate-limited
ALPHAVANTAGE_API_KEY=

# Massive.com — https://massive.com
# Used by: tick-level intraday data, MCP integration
# Required only if --source=massive
MASSIVE_API_KEY=

# ============================================================
# BACKTEST STORAGE (S3-compatible flat files)
# ============================================================

# Required only if --source=backtest
BACKTEST_ACCESS_KEY=
BACKTEST_SECRET_KEY=
BACKTEST_BUCKET=flatfiles
BACKTEST_ENDPOINT=https://files.massive.com

# ============================================================
# ALERTS (optional)
# ============================================================

# Slack incoming webhook — https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# SMTP (for email alerts)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# Minimum score (0-100) to trigger an alert
ALERT_SCORE_THRESHOLD=75

# ============================================================
# TUNING (optional — defaults are usually fine)
# ============================================================

# Cache TTL in minutes
YAHOO_CACHE_TTL_MINUTES=5
FINVIZ_CACHE_TTL_MINUTES=10

# Screener thresholds
MIN_GAP_PCT=2.0
MIN_PREMARKET_VOLUME=200000
MIN_PRICE=2.0
MAX_PRICE=200.0
